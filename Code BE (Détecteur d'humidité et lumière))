/**
  * @brief  Point d'entrée du programme.
  *         Initialise les périphériques, démarre le PWM de la LED,
  *         affiche un message de démarrage, puis boucle en lisant
  *         les deux capteurs et en mettant à jour le LCD toutes les ~500 ms.
  */
int main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  HAL_Init();               /* Initialisation de la HAL (SysTick, NVIC, etc.) */

  /* USER CODE BEGIN Init */
  /* USER CODE END Init */

  SystemClock_Config();     /* Configuration de l'horloge système (PLL → 80 MHz) */

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  MX_GPIO_Init();           /* Initialisation des GPIO */
  MX_ADC1_Init();           /* Initialisation de l'ADC1 (capteurs humidité + lumière) */
  MX_I2C1_Init();           /* Initialisation de l'I2C1 (LCD) */
  MX_TIM2_Init();           /* Initialisation du TIM2 (PWM LED) */

  /* USER CODE BEGIN 2 */

  /* --- Démarrage du PWM sur TIM2 canal 1 (commande LED) ---
   * Compare register = 250 ; rapport cyclique = 250 / ARR (défini dans MX_TIM2_Init). */
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);
  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 250);   /* Rapport cyclique fixe */

  /* --- Initialisation et message de démarrage sur le LCD --- */
  LCD_Init();
  LCD_SetCursor(0, 0);
  LCD_Print("Moisture sensor");
  LCD_SetCursor(1, 0);
  LCD_Print("Init OK");
  HAL_Delay(800);           /* Affichage pendant 800 ms */
  LCD_Clear();

  /* USER CODE END 2 */

  /* Boucle principale — rafraîchissement toutes les ~500 ms */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
  /* USER CODE END WHILE */

  /* USER CODE BEGIN 3 */

    /* --- Mesure humidité sol --- */
    float v   = ReadMoistureVoltage();      /* Tension brute en volts */
    float pct = VoltageToPercent(v);        /* Conversion en % humidité */

    /* Formatage entier (évite %f dans snprintf, plus léger sur µC) :
     * v_mV = tension en millivolts arrondie, pct_i = pourcentage arrondi. */
    int v_mV  = (int)(v * 1000.0f + 0.5f);
    int pct_i = (int)(pct + 0.5f);
    snprintf(line1, sizeof(line1), "V=%d.%03dV %3d%%",
             v_mV / 1000, v_mV % 1000, pct_i); /* Ex : "V=1.823V  42%" */

    /* --- Mesure luminosité --- */
    uint32_t light_raw = ReadLightRaw();            /* Valeur brute ADC [0 ; 4095] */
    float light_pct    = LightRawToPercent(light_raw);
    int light_i        = (int)(light_pct + 0.5f);  /* Arrondi entier */
    snprintf(line2, sizeof(line2), "Light: %3d%%", light_i);  /* Ex : "Light:  67%" */

    /* --- Mise à jour LCD ligne 1 (humidité) ---
     * Effacement manuel par 16 espaces avant l'écriture pour éviter les artefacts
     * résiduels (pas de LCD_Clear pour ne pas provoquer de clignotement visible). */
    LCD_SetCursor(0, 0);
    LCD_Print("                ");
    LCD_SetCursor(0, 0);
    LCD_Print(line1);

    /* --- Mise à jour LCD ligne 2 (luminosité) --- */
    LCD_SetCursor(1, 0);
    LCD_Print("                ");
    LCD_SetCursor(1, 0);
    LCD_Print(line2);

    /* Remet l'ADC sur le canal humidité avant la prochaine itération,
     * puis attend 500 ms (cadence de rafraîchissement). */
    ADC_SelectChannel(MOIST_ADC_CHANNEL);
    HAL_Delay(500);

  }
  /* USER CODE END 3 */
}

/**
  * @brief Configuration de l'horloge système.
  *
  *        Source : HSI (16 MHz)
  *        PLL : × 10 / 2 → SYSCLK = 80 MHz
  *        AHB, APB1, APB2 : diviseur 1 → 80 MHz
  *        Latence Flash : 4 wait states (requis à 80 MHz, VDD = 3,3 V, VOS1)
  */
void SystemClock_Config(void)
{
  RCC_OscInitTypeDef RCC_OscInitStruct = {0};
  RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

  /* Mise à l'échelle du régulateur de tension (VOS1 requis pour 80 MHz) */
  if (HAL_PWREx_ControlVoltageScaling(PWR_REGULATOR_VOLTAGE_SCALE1) != HAL_OK)
    Error_Handler();

  /* Configuration de l'oscillateur HSI et de la PLL */
  RCC_OscInitStruct.OscillatorType      = RCC_OSCILLATORTYPE_HSI;
  RCC_OscInitStruct.HSIState            = RCC_HSI_ON;
  RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
  RCC_OscInitStruct.PLL.PLLState        = RCC_PLL_ON;
  RCC_OscInitStruct.PLL.PLLSource       = RCC_PLLSOURCE_HSI;   /* Entrée PLL : HSI 16 MHz */
  RCC_OscInitStruct.PLL.PLLM            = 1;                    /* Prédiviseur : ÷1 → 16 MHz */
  RCC_OscInitStruct.PLL.PLLN            = 10;                   /* Multiplicateur : ×10 → 160 MHz VCO */
  RCC_OscInitStruct.PLL.PLLP            = RCC_PLLP_DIV7;       /* Sortie PLLP : ÷7 (SAI) */
  RCC_OscInitStruct.PLL.PLLQ            = RCC_PLLQ_DIV2;       /* Sortie PLLQ : ÷2 → 80 MHz (USB/RNG) */
  RCC_OscInitStruct.PLL.PLLR            = RCC_PLLR_DIV2;       /* Sortie PLLR : ÷2 → 80 MHz (SYSCLK) */
  if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
    Error_Handler();

  /* Configuration des horloges de bus */
  RCC_ClkInitStruct.ClockType      = RCC_CLOCKTYPE_HCLK | RCC_CLOCKTYPE_SYSCLK
                                   | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
  RCC_ClkInitStruct.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK;  /* SYSCLK = PLLR = 80 MHz */
  RCC_ClkInitStruct.AHBCLKDivider  = RCC_SYSCLK_DIV1;          /* HCLK  = 80 MHz */
  RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV1;            /* PCLK1 = 80 MHz */
  RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;            /* PCLK2 = 80 MHz */
  if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_4) != HAL_OK)
    Error_Handler();
}

