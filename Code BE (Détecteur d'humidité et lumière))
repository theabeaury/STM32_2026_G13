/* ═══════════════════════════════════════════════════════════
 *  LCD (contrôleur ST7032 ou compatible, interface I2C)
 *
 *  Protocole : chaque transfert I2C = 2 octets :
 *    - octet de contrôle : 0x80 = commande, 0x40 = donnée (caractère)
 *    - octet de données
 * ═══════════════════════════════════════════════════════════ */

/**
 * @brief Envoie une commande au contrôleur LCD via I2C.
 * @param cmd  Code de commande (ex. 0x01 = Clear, 0x0C = Display ON).
 */
static void LCD_SendCommand(uint8_t cmd)
{
    uint8_t buf[2] = {0x80, cmd};  /* 0x80 = octet de contrôle "commande" */
    HAL_I2C_Master_Transmit(&hi2c1, LCD_I2C_ADDR, buf, 2, 100);
}

/**
 * @brief Envoie un caractère ASCII à afficher à la position courante du curseur.
 * @param c  Caractère à afficher.
 */
static void LCD_SendChar(uint8_t c)
{
    uint8_t buf[2] = {0x40, c};   /* 0x40 = octet de contrôle "donnée" */
    HAL_I2C_Master_Transmit(&hi2c1, LCD_I2C_ADDR, buf, 2, 100);
}

/**
 * @brief Efface l'écran LCD et replace le curseur en position (0, 0).
 *        Un délai de 2 ms est requis après la commande Clear Display.
 */
static void LCD_Clear(void)
{
    LCD_SendCommand(0x01);  /* Commande "Clear Display" */
    HAL_Delay(2);           /* Délai d'exécution requis par le contrôleur */
}

/**
 * @brief Initialise le LCD selon la séquence de démarrage du ST7032.
 *        Configure le mode 8 bits, 2 lignes, et active le générateur de tension interne.
 */
static void LCD_Init(void)
{
    HAL_Delay(50);              /* Attente stabilisation alimentation (>40 ms après VDD) */
    LCD_SendCommand(0x38);      /* Function Set : 8 bits, 2 lignes, mode normal */
    LCD_SendCommand(0x39);      /* Function Set : mode extension IS=1 */
    LCD_SendCommand(0x14);      /* Internal OSC frequency */
    LCD_SendCommand(0x70);      /* Contrast set (bits C3:C0) */
    LCD_SendCommand(0x56);      /* Power/ICON/Contrast : booster ON */
    LCD_SendCommand(0x6C);      /* Follower control activé */
    HAL_Delay(200);             /* Délai de stabilisation de l'ampli suiveur */
    LCD_SendCommand(0x38);      /* Retour en mode normal (IS=0) */
    LCD_SendCommand(0x0C);      /* Display ON, curseur OFF, blink OFF */
    LCD_Clear();                /* Effacement initial */
}

/**
 * @brief Positionne le curseur LCD à la ligne et colonne spécifiées.
 * @param row  Ligne : 0 = première ligne, 1 = deuxième ligne.
 * @param col  Colonne : 0 à 15.
 * @note  L'adresse DDRAM de la ligne 1 commence à 0x40 (standard LCD 16x2).
 */
static void LCD_SetCursor(uint8_t row, uint8_t col)
{
    uint8_t addr = (row == 0) ? 0x00 : 0x40;   /* Adresse DDRAM de base selon la ligne */
    LCD_SendCommand(0x80 | (addr + col));        /* Commande "Set DDRAM Address" */
}

/**
 * @brief Affiche une chaîne de caractères à la position courante du curseur.
 * @param s  Pointeur vers la chaîne terminée par '\0'.
 */
static void LCD_Print(const char *s)
{
    while (*s)
        LCD_SendChar((uint8_t)*s++);  /* Envoie chaque caractère jusqu'au '\0' */
}

/* ═══════════════════════════════════════════════════════════
 *  ADC — fonctions de lecture des capteurs
 * ═══════════════════════════════════════════════════════════ */

/**
 * @brief Reconfigure dynamiquement le canal actif de l'ADC1.
 *
 *        L'ADC1 est partagé entre le capteur d'humidité (CH15) et la
 *        photorésistance (CH6). Cette fonction change le canal sans
 *        réinitialiser l'ADC entier.
 *
 * @param channel  Canal ADC à sélectionner (ex. ADC_CHANNEL_15).
 */
static void ADC_SelectChannel(uint32_t channel)
{
    ADC_ChannelConfTypeDef sConfig = {0};
    sConfig.Channel      = channel;
    sConfig.Rank         = ADC_REGULAR_RANK_1;            /* Un seul canal en séquence régulière */
    sConfig.SamplingTime = ADC_SAMPLETIME_47CYCLES_5;     /* Temps d'échantillonnage : 47,5 cycles */
    (void)HAL_ADC_ConfigChannel(&hadc1, &sConfig);
}

/**
 * @brief Lit la tension analogique en sortie du capteur d'humidité du sol.
 *
 *        Sélectionne le canal ADC_CHANNEL_15, lance une conversion simple,
 *        et convertit la valeur brute en tension (V).
 *        Formule : V = raw × VREF / ADC_MAX_COUNTS
 *
 * @return Tension en volts [0,0 ; 3,3], ou 0,0 en cas d'erreur de conversion.
 */
static float ReadMoistureVoltage(void)
{
    ADC_SelectChannel(MOIST_ADC_CHANNEL);
    HAL_Delay(1);                    /* Délai de stabilisation du multiplexeur ADC */
    HAL_ADC_Start(&hadc1);
    if (HAL_ADC_PollForConversion(&hadc1, 10) != HAL_OK)
    {
        HAL_ADC_Stop(&hadc1);
        return 0.0f;                 /* Timeout conversion → valeur nulle de sécurité */
    }
    uint32_t raw = HAL_ADC_GetValue(&hadc1);
    HAL_ADC_Stop(&hadc1);
    return ((float)raw * VREF) / ADC_MAX_COUNTS;  /* Conversion counts → volts */
}

/**
 * @brief Convertit une tension capteur d'humidité en pourcentage d'humidité sol.
 *
 *        Interpolation linéaire entre DRY_VOLTAGE (0 %) et WET_VOLTAGE (100 %).
 *        Les valeurs hors plage sont clampées à 0 % ou 100 %.
 *
 * @param v  Tension lue sur le capteur (V).
 * @return   Humidité en % [0,0 ; 100,0].
 */
static float VoltageToPercent(float v)
{
    if (v <= DRY_VOLTAGE) return 0.0f;    /* Sol sec : limite basse */
    if (v >= WET_VOLTAGE) return 100.0f;  /* Sol saturé : limite haute */
    float p = ((v - DRY_VOLTAGE) / (WET_VOLTAGE - DRY_VOLTAGE)) * 100.0f;
    return p;
}

/**
 * @brief Lit la valeur brute ADC de la photorésistance (canal ADC_CHANNEL_6).
 *
 *        Une première conversion est effectuée et ignorée pour laisser le temps
 *        au multiplexeur et à l'échantillonneur-bloqueur de se stabiliser après
 *        le changement de canal (charge résiduelle du canal précédent).
 *        La deuxième conversion est la valeur retournée.
 *
 *        Le temps d'échantillonnage plus long (247,5 cycles) compense l'impédance
 *        de source élevée d'une photorésistance.
 *
 * @return Valeur brute ADC [0 ; 4095], ou 0 en cas d'erreur.
 */
static uint32_t ReadLightRaw(void)
{
    ADC_ChannelConfTypeDef sConfig = {0};
    sConfig.Channel      = LIGHT_ADC_CHANNEL;
    sConfig.Rank         = ADC_REGULAR_RANK_1;
    sConfig.SamplingTime = ADC_SAMPLETIME_247CYCLES_5;   /* Temps long pour haute impédance source */
    if (HAL_ADC_ConfigChannel(&hadc1, &sConfig) != HAL_OK) return 0;

    /* --- Première conversion ignorée (purge du sample-and-hold) --- */
    HAL_ADC_Start(&hadc1);
    if (HAL_ADC_PollForConversion(&hadc1, 10) == HAL_OK)
        (void)HAL_ADC_GetValue(&hadc1);   /* Valeur lue mais jetée volontairement */
    HAL_ADC_Stop(&hadc1);

    /* --- Deuxième conversion : valeur exploitable --- */
    HAL_ADC_Start(&hadc1);
    if (HAL_ADC_PollForConversion(&hadc1, 10) != HAL_OK)
    {
        HAL_ADC_Stop(&hadc1);
        return 0;   /* Timeout → valeur nulle de sécurité */
    }
    uint32_t raw = HAL_ADC_GetValue(&hadc1);
    HAL_ADC_Stop(&hadc1);
    return raw;
}

/**
 * @brief Convertit une valeur brute ADC de photorésistance en pourcentage de luminosité.
 *
 *        Interpolation linéaire entre LIGHT_RAW_DARK (0 %) et LIGHT_RAW_BRIGHT (100 %).
 *        Les valeurs hors plage sont clampées.
 *
 * @param raw  Valeur brute ADC [0 ; 4095].
 * @return     Luminosité en % [0,0 ; 100,0].
 */
static float LightRawToPercent(uint32_t raw)
{
    float v = (float)raw;
    if (v <= LIGHT_RAW_DARK)   return 0.0f;    /* Obscurité totale */
    if (v >= LIGHT_RAW_BRIGHT) return 100.0f;  /* Plein soleil */
    float p = ((v - LIGHT_RAW_DARK) / (LIGHT_RAW_BRIGHT - LIGHT_RAW_DARK)) * 100.0f;
    return p;
}

