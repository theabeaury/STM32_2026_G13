/* Adresse I2C du LCD (ST7032 ou compatible), décalée d'un bit pour HAL */
#define LCD_I2C_ADDR      (0x3E << 1)

/* Référence de tension ADC (VDD = 3,3 V) */
#define VREF              (3.3f)

/* Résolution ADC 12 bits → 4095 niveaux */
#define ADC_MAX_COUNTS    (4095.0f)

/* Canaux ADC utilisés */
#define MOIST_ADC_CHANNEL ADC_CHANNEL_15   /* Capteur d'humidité sol */
#define LIGHT_ADC_CHANNEL ADC_CHANNEL_6    /* Photorésistance */

/* Plage de calibration du capteur d'humidité (mesurée à sec et dans l'eau) */
#define DRY_VOLTAGE       (1.6f)    /* Tension = sol sec → 0 % humidité */
#define WET_VOLTAGE       (2.5f)    /* Tension = sol saturé → 100 % humidité */

/* Plage de calibration de la photorésistance (valeurs brutes ADC) */
#define LIGHT_RAW_DARK    (0.48f * ADC_MAX_COUNTS)   /* Obscurité totale → 0 % luminosité */
#define LIGHT_RAW_BRIGHT  (0.82f * ADC_MAX_COUNTS)   /* Plein soleil → 100 % luminosité */

