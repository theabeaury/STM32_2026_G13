#define LCD_I2C_ADDR (0x3E << 1)          // adresse I2C du LCD Grove (décalée pour HAL)
#define VREF (3.3f)                       // tension de référence ADC
#define ADC_MAX_COUNTS (4095.0f)          // valeur max ADC 12 bits
#define MOIST_ADC_CHANNEL ADC_CHANNEL_15  // canal ADC du capteur d’humidité (PB0)
#define LIGHT_ADC_CHANNEL ADC_CHANNEL_6   // canal ADC du capteur de lumière (PA1)
