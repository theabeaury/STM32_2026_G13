#define WET_VOLTAGE (2.5f)                // tension mesurée correspondant à 100% humidité
#define LIGHT_RAW_DARK (0.48f * ADC_MAX_COUNTS)   // valeur ADC en obscurité
#define LIGHT_RAW_BRIGHT (0.9f * ADC_MAX_COUNTS)  // valeur ADC en forte lumière

